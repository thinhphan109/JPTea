# JPTea — Server-side environment variables
# Copy this file to `.env` and fill in your values
# `.env` is gitignored — NEVER commit it

# ============================================
# AI Provider (server-side, NOT exposed to browser)
# ============================================
# Note: NO `VITE_` prefix → these stay on server only

# Provider: openai | groq | together | openrouter | ollama | custom
AI_PROVIDER=groq

# Base URL (auto-defaulted per provider, override only if needed)
AI_BASE_URL=https://api.groq.com/openai/v1

# API Key — required for cloud providers (NOT for ollama)
# Get keys from:
#   - OpenAI:     https://platform.openai.com/api-keys
#   - Groq:       https://console.groq.com/keys (FREE)
#   - Together:   https://api.together.xyz/settings/api-keys
#   - OpenRouter: https://openrouter.ai/keys
AI_API_KEY=

# Model name (e.g. llama-3.1-8b-instant, gpt-4o-mini, claude-3-haiku)
AI_MODEL=llama-3.1-8b-instant

# Enable AI features (true/false)
AI_ENABLED=false

# ============================================
# 🔒 SECURITY MODEL
# ============================================
# These vars NEVER reach the browser. The frontend calls /api/chat which
# proxies to the AI provider using AI_API_KEY (server-only).
#
# Browser → /api/chat → Provider API
#                ^
#                key lives here
#
# To deploy on Vercel/Netlify: add these vars in the dashboard
# (Settings → Environment Variables), redeploy.
